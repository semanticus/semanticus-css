{
  "name": "@goncalvesjoao/semanticus-css",
  "version": "0.2.0",
  "description": "lightweight CSS framework that prioritizes semantic HTML and ARIA-focused accessibility, with a small set of atomic utilities",
  "author": "Joao Goncalves",
  "style": "./dist/semanticus.css",
  "main": "./dist/semanticus.css",
  "unpkg": "./dist/semanticus.min.css",
  "jsdelivr": "./dist/semanticus.min.css",
  "exports": {
    ".": "./dist/semanticus.css",
    "./min": "./dist/semanticus.min.css",
    "./semantics": "./dist/semanticus-semantics.css",
    "./semantics/min": "./dist/semanticus-semantics.min.css",
    "./utilities": "./dist/semanticus-utilities.css",
    "./utilities/min": "./dist/semanticus-utilities.min.css",
    "./variants": "./dist/semanticus-variants.css",
    "./variants/min": "./dist/semanticus-variants.min.css",
    "./palettes/*": "./dist/semanticus.palette.*.css",
    "./sizes/*": "./dist/semanticus.size.*.css",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "NOTICE",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/goncalvesjoao/semanticus-css.git"
  },
  "homepage": "https://github.com/goncalvesjoao/semanticus-css#readme",
  "bugs": {
    "url": "https://github.com/goncalvesjoao/semanticus-css/issues"
  },
  "keywords": [
    "css",
    "css-framework",
    "utility-first",
    "picocss",
    "bootstrap-utilities",
    "semantic",
    "semantic-css",
    "functional-css",
    "design",
    "responsive",
    "performance",
    "dark-mode",
    "dark-theme",
    "lightweight",
    "minimal",
    "native-html"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.12.1",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": [
    "dist/**/*.css",
    "src/**/*.css"
  ],
  "devDependencies": {
    "backstopjs": "^6.3.25",
    "browserslist": "^4.28.2",
    "highlight.js": "^11.11.1",
    "lightningcss": "^1.32.0",
    "lightningcss-cli": "^1.32.0",
    "puppeteer": "^23.0.0",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "vitepress": "^2.0.0-alpha.17"
  },
  "scripts": {
    "start": "npm run docs:dev",
    "demo": "node scripts/demo.js",
    "lint": "stylelint \"src/**/*.css\"",
    "lint:fix": "stylelint \"src/**/*.css\" --fix",
    "test": "npx backstopjs test",
    "test:snapshot": "npx backstopjs reference",
    "test:kill-zombies": "pkill -f '(chrome)?(--headless)'",
    "check": "npm run lint && npm run build",
    "prepublishOnly": "npm run lint && npm run build",
    "release:update-cdn-urls": "node scripts/update-cdn-urls.js",
    "build": "npm run build:css && npm run build:minify && npm run build:palettes && npm run build:sizes && npm run build:update-size-claims",
    "build:css": "npm run build:full && npm run build:semantics && npm run build:variants && npm run build:utilities",
    "build:full": "lightningcss --bundle --browserslist src/index.css -o dist/semanticus.css --custom-media",
    "build:semantics": "lightningcss --bundle --browserslist src/semantics/index.css -o dist/semanticus-semantics.css --custom-media",
    "build:variants": "lightningcss --bundle --browserslist src/variants/index.css -o dist/semanticus-variants.css --custom-media",
    "build:utilities": "lightningcss --bundle --browserslist src/utilities/index.css -o dist/semanticus-utilities.css --custom-media",
    "build:minify": "npm run build:minify:full && npm run build:minify:semantics && npm run build:minify:variants && npm run build:minify:utilities",
    "build:minify:full": "lightningcss --bundle --minify --browserslist src/index.css -o dist/semanticus.min.css --custom-media",
    "build:minify:semantics": "lightningcss --bundle --minify --browserslist src/semantics/index.css -o dist/semanticus-semantics.min.css --custom-media",
    "build:minify:variants": "lightningcss --bundle --minify --browserslist src/variants/index.css -o dist/semanticus-variants.min.css --custom-media",
    "build:minify:utilities": "lightningcss --bundle --minify --browserslist src/utilities/index.css -o dist/semanticus-utilities.min.css --custom-media",
    "build:palettes": "node scripts/build-palettes.js",
    "build:sizes": "node scripts/build-sizes.js",
    "build:update-size-claims": "node scripts/update-size-claims.js",
    "docs:dev": "npm run build && vitepress dev docs",
    "docs:build": "npm run build && vitepress build docs",
    "docs:preview": "npm run build && vitepress preview docs"
  }
}
