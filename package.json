{
  "name": "@semanticus/semanticus-css",
  "version": "0.8.1",
  "description": "lightweight CSS framework that prioritizes semantic HTML and ARIA-focused accessibility, with a small set of atomic utilities",
  "author": "Joao Goncalves",
  "style": "./dist/semanticus.css",
  "main": "./dist/semanticus.css",
  "unpkg": "./dist/semanticus.css",
  "jsdelivr": "./dist/semanticus.css",
  "exports": {
    ".": "./dist/semanticus.css",
    "./semantics": "./dist/semanticus-semantics.css",
    "./palettes/*": "./dist/semanticus.palette.*.css",
    "./sizes/*": "./dist/semanticus.size.*.css",
    "./src/*": "./src/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "NOTICE",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/semanticus/semanticus-css.git"
  },
  "homepage": "https://semanticus.design",
  "bugs": {
    "url": "https://github.com/semanticus/semanticus-css/issues"
  },
  "keywords": [
    "css",
    "css-framework",
    "utility-first",
    "picocss",
    "bootstrap-utilities",
    "semantic",
    "semantic-css",
    "functional-css",
    "design",
    "responsive",
    "performance",
    "dark-mode",
    "dark-theme",
    "lightweight",
    "minimal",
    "native-html"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.12.1",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": [
    "dist/**/*.css",
    "src/**/*.css"
  ],
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/html": "^10.3.5",
    "@storybook/html-vite": "^10.3.5",
    "@types/node": "^25.6.0",
    "browserslist": "^4.28.2",
    "highlight.js": "^11.11.1",
    "lightningcss": "^1.32.0",
    "lightningcss-cli": "^1.32.0",
    "storybook": "^10.3.5",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "vitepress": "^2.0.0-alpha.17"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "start": "npm run docs:dev",
    "demo": "node scripts/demo.js",
    "lint": "stylelint \"src/**/*.css\"",
    "lint:fix": "stylelint \"src/**/*.css\" --fix",
    "check": "npm run lint && npm run build",
    "test:visual-regression": "npx playwright test",
    "test:update-snapshots": "npx playwright test -u",
    "prepublishOnly": "npm run lint && npm run build",
    "release:sync-versions": "node scripts/sync-version-references.js",
    "build": "npm run build:css && npm run build:palettes && npm run build:sizes && npm run build:update-size-claims",
    "build:css": "npm run build:full && npm run build:semantics",
    "build:full": "lightningcss --bundle --minify --browserslist src/index.css -o dist/semanticus.css --custom-media",
    "build:semantics": "lightningcss --bundle --minify --browserslist src/semantics/index.css -o dist/semanticus-semantics.css --custom-media",
    "build:palettes": "node scripts/build-palettes.js",
    "build:sizes": "node scripts/build-sizes.js",
    "build:update-size-claims": "node scripts/update-size-claims.js",
    "docs:dev": "npm run build && vitepress dev docs",
    "docs:build": "npm run build && vitepress build docs",
    "docs:preview": "npm run build && vitepress preview docs"
  }
}
