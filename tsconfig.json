{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2020", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strict": false,
    "types": ["node"],
    "paths": {
      "@demos/*": ["./demos/*"],
      "@stories/*": ["./stories/*"],
      "@tests/*": ["./tests/*"],
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "demos/**/*",
    "stories/**/*",
    "scripts/**/*",
    "*.ts",
    "*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "html_report",
    "public",
    "demo"
  ]
}
